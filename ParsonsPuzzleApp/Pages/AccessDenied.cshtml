@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Достъпът е отказан";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body text-center">
                    <h1 class="text-danger">
                        <i class="fas fa-exclamation-triangle"></i>
                    </h1>
                    <h2>Достъпът е отказан</h2>
                    <p class="text-muted">@Model.Message</p>
                    <hr />
                    <p>Възможни причини:</p>
                    <ul class="text-start">
                        <li>Връзката е невалидна или изтекла</li>
                        <li>Колекцията не е публикувана</li>
                        <li>Не сте въвели правилен код за отключване</li>
                        <li>Сесията ви е изтекла (след 24 часа)</li>
                    </ul>
                    <div class="mt-4">
                        <a href="/" class="btn btn-primary">Към началната страница</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>