@page
@model SolvePuzzleModel
@{
    Layout = "_Layout";
}

@{
    ViewData["Title"] = "Решаване на пъзели";
}

<div class="container-fluid d-flex flex-column" style="height: 100vh; padding: 0; overflow: hidden;">
    <div class="header-section d-flex justify-content-between align-items-center p-3 bg-light">
        <h3>Пъзел @Model.PuzzleIndex от @Model.TotalPuzzles - @Model.Puzzle.Language</h3>
        <div>
            <button class="btn btn-info me-2" data-bs-toggle="modal" data-bs-target="#taskModal">Условие на заданието</button>
            <button class="btn btn-primary me-2" onclick="checkSolution()">Провери</button>
            <button class="btn btn-success me-2" onclick="submitSolution()">Подай</button>
            <button class="btn btn-danger" onclick="if(confirm('Сигурни ли сте?')) resetPuzzle()">Рестарт</button>
        </div>
    </div>
    <div class="middle-section flex-grow-1 d-flex overflow-hidden">
        <div class="left-panel p-3 bg-light overflow-auto" style="flex: 1; background-color: #f8f9fa;" id="sourcePanel">
            @foreach (var block in Model.ShuffledCodeBlocks)
            {
                <div class="code-block @(block.IsDistractor ? "distractor" : "")" id="block-@Model.ShuffledCodeBlocks.IndexOf(block)">
                    @if (!string.IsNullOrEmpty(block.SlotName))
                    {
                        <span class="code-content">@Html.Raw(block.Content.Replace($"§{block.SlotName}§", "<span class='slot' data-slot='" + block.SlotName + "'></span>"))</span>
                    }
                    else
                    {
                        <span class="code-content">@block.Content</span>
                    }
                    <span class="indent-btns">
                        <button onclick="shiftLeft(this)" class="btn btn-sm btn-outline-secondary mx-1">&lt;</button>
                        <button onclick="shiftRight(this)" class="btn btn-sm btn-outline-secondary">&gt;</button>
                    </span>
                </div>
            }
        </div>
        <div class="right-panel p-3 bg-white overflow-auto" style="flex: 1;" id="targetPanel"></div>
    </div>
    <div class="mini-blocks-panel p-3 bg-light" id="miniBlocksPanel">
        @foreach (var mb in Model.MiniBlocks)
        {
            <div class="mini-block" id="mini-@Model.MiniBlocks.IndexOf(mb)">@mb.Content</div>
        }
    </div>
</div>

<div class="modal fade" id="taskModal" tabindex="-1" aria-labelledby="taskModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="taskModalLabel">Условие на заданието</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @Html.Raw(Model.Puzzle.Task)
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <style>
        .code-block, .brace-block {
            position: relative;
            background-color: #f8f9fa;
            border: 1px solid #dee2e6;
            padding: 10px;
            margin-bottom: 5px;
            cursor: move;
            transition: background-color 0.2s;
            font-family: 'Courier New', Courier, monospace;
            min-height: 30px;
            white-space: nowrap;
        }

            .code-block:hover {
                background-color: #e9ecef;
            }

        .source-panel .code-block {
            background-color: #e2f0fd;
        }

        .target-panel .code-block {
            background-color: #f0f9e8;
        }

        .brace-block {
            background-color: #f2f2f2;
            color: #666;
            border-left: 2px solid #007bff;
            padding: 2px 8px;
            margin: 2px 0;
            font-size: 0.85rem;
            user-select: none;
        }

        .code-content {
            display: inline-block;
            vertical-align: middle;
        }

        .slot {
            display: inline-block;
            min-width: 50px;
            height: 22px;
            background-color: #e9ecef;
            border: 1px dashed #adb5bd;
            vertical-align: middle;
            white-space: nowrap;
            position: relative;
        }

            .slot.filled {
                min-width: auto;
                padding: 0;
            }

        .mini-block {
            display: inline-block;
            padding: 2px 6px;
            margin: 2px;
            background-color: #d1e7dd;
            border: 1px solid #adb5bd;
            cursor: move;
            text-align: center;
            font-family: 'Courier New', Courier, monospace;
            white-space: nowrap;
            font-size: 0.85rem;
            line-height: 14px;
        }

        .remove-mini-block {
            position: absolute;
            top: -8px;
            right: -8px;
            background-color: #dc3545;
            color: white;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            line-height: 20px;
            text-align: center;
            cursor: pointer;
            display: none;
        }

        .slot:hover .remove-mini-block {
            display: block;
        }

        .indent-0 {
            margin-left: 0;
        }

        .indent-1 {
            margin-left: 20px;
        }

        .indent-2 {
            margin-left: 40px;
        }

        .indent-3 {
            margin-left: 60px;
        }

        .indent-4 {
            margin-left: 80px;
        }

        .indent-5 {
            margin-left: 100px;
        }

        .header-section {
            width: 100%;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .middle-section {
            display: flex;
            flex-direction: row;
            flex-grow: 1;
            overflow: hidden;
        }

        .left-panel, .right-panel {
            flex: 1;
            overflow-y: auto;
        }

        .mini-blocks-panel {
            background-color: #f8f9fa;
            border-top: 1px solid #dee2e6;
        }

        .sortable-ghost {
            background-color: #cce5ff;
            border: 2px dashed #007bff;
            opacity: 0.7;
        }

        .indent-btns {
            display: none;
            position: absolute;
            right: 5px;
            top: 50%;
            transform: translateY(-50%);
        }

        .code-block:hover .indent-btns {
            display: inline;
        }

        .drop-target-indicator {
            height: 2px;
            background-color: #1890ff;
            position: absolute;
            z-index: 1000;
            transition: all 0.1s ease;
            display: none;
        }

        .multiline-block {
            background: #f8f9fa;
            border: 2px solid #dee2e6;
            border-radius: 8px;
            margin-bottom: 0.5rem;
            overflow: hidden;
        }

        .multiline-container {
            padding: 0.5rem;
        }

        .code-line {
            display: flex;
            align-items: center;
            padding: 0.25rem 0.5rem;
            margin: 0.125rem 0;
            background: white;
            border-radius: 4px;
            transition: background 0.2s;
        }

            .code-line:hover {
                background: #e9ecef;
            }

        .line-content {
            flex: 1;
            font-family: 'Monaco', 'Consolas', monospace;
            font-size: 14px;
        }

        .drag-handle {
            cursor: move;
            padding: 0 0.5rem;
            color: #adb5bd;
            user-select: none;
        }

        .multiline-controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.5rem;
            background: #e9ecef;
            border-top: 1px solid #dee2e6;
        }

        .toggle-btn {
            background: none;
            border: none;
            cursor: pointer;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            transition: background 0.2s;
        }

            .toggle-btn:hover {
                background: #dee2e6;
            }

        .block-type-indicator {
            font-size: 12px;
            color: #6c757d;
            text-transform: uppercase;
            font-weight: 600;
        }


    </style>
    <script>
        let startTime = Date.now();
        const dropIndicator = document.createElement('div');
        dropIndicator.className = 'drop-target-indicator';
        document.body.appendChild(dropIndicator);

        class PuzzleBlockManager {
            constructor() {
                this.blocks = new Map();
                this.groupDefinitions = new Map();
            }

            initializePuzzleBlocks(blockConfigs) {
                blockConfigs.forEach(config => {
                    if (config.blockType === 'multiline') {
                        this.createMultilineBlock(config);
                    }
                });
            }

            createMultilineBlock(config) {
                const blockId = `puzzle-block-${config.groupId}`;
                const blockElement = document.createElement('div');
                blockElement.className = 'code-block multiline-block';
                blockElement.id = blockId;
                blockElement.dataset.groupId = config.groupId;
                blockElement.dataset.orderIndependent = config.orderMatters ? 'false' : 'true';

                const linesContainer = document.createElement('div');
                linesContainer.className = 'multiline-container';

                config.lines.forEach((line, index) => {
                    const lineElement = this.createLineElement(line, index, config);
                    linesContainer.appendChild(lineElement);
                });

                blockElement.appendChild(linesContainer);

                const controls = this.createMultilineControls(config);
                blockElement.appendChild(controls);

                return blockElement;
            }

            createLineElement(line, index, config) {
                const lineDiv = document.createElement('div');
                lineDiv.className = 'code-line';
                lineDiv.dataset.lineIndex = index;
                lineDiv.dataset.optional = line.optional || false;

                const content = document.createElement('span');
                content.className = 'line-content';
                content.textContent = line.content;
                lineDiv.appendChild(content);

                if (config.orderMatters === false) {
                    const handle = document.createElement('span');
                    handle.className = 'drag-handle';
                    handle.innerHTML = '⋮⋮';
                    lineDiv.appendChild(handle);
                }

                return lineDiv;
            }

            createMultilineControls(config) {
                const controls = document.createElement('div');
                controls.className = 'multiline-controls';

                const toggleBtn = document.createElement('button');
                toggleBtn.className = 'toggle-btn';
                toggleBtn.innerHTML = '▼';
                toggleBtn.onclick = () => this.toggleBlockView(config.groupId);
                controls.appendChild(toggleBtn);

                const typeIndicator = document.createElement('span');
                typeIndicator.className = 'block-type-indicator';
                typeIndicator.textContent = config.blockType;
                controls.appendChild(typeIndicator);

                return controls;
            }

            toggleBlockView(groupId) {
                const block = document.getElementById(`puzzle-block-${groupId}`);
                const container = block.querySelector('.multiline-container');
                const toggleBtn = block.querySelector('.toggle-btn');
                const isCollapsed = block.classList.contains('collapsed');

                if (isCollapsed) {
                    block.classList.remove('collapsed');
                    container.style.display = 'block';
                    toggleBtn.innerHTML = '▼';
                } else {
                    block.classList.add('collapsed');
                    container.style.display = 'none';
                    toggleBtn.innerHTML = '▶';
                }
            }

            exportSolution(targetPanel) {
                const blocks = targetPanel.querySelectorAll('.code-block');
                let solution = [];

                blocks.forEach(block => {
                    if (block.classList.contains('multiline-block')) {
                        const lines = Array.from(block.querySelectorAll('.code-line'));
                        lines.forEach(line => {
                            const content = line.querySelector('.line-content').textContent;
                            const indent = parseInt(block.style.marginLeft || 0) / 20;
                            solution.push('  '.repeat(indent) + content);
                        });
                    } else {
                        const content = block.querySelector('.code-content')?.textContent || block.textContent;
                        const indent = parseInt(block.style.marginLeft || 0) / 20;
                        solution.push('  '.repeat(indent) + content);
                    }
                });

                return solution.join('\n');
            }
        }

        const blockManager = new PuzzleBlockManager();

        function initializePuzzle() {
            const sourcePanel = document.getElementById('sourcePanel');
            const targetPanel = document.getElementById('targetPanel');
            const miniBlocksPanel = document.getElementById('miniBlocksPanel');


            @if (Model.PuzzleBlocks != null && Model.PuzzleBlocks.Any())
            {
                    <text>
                    const puzzleBlocks = @Html.Raw(Json.Serialize(Model.PuzzleBlocks));
                            puzzleBlocks.forEach(block => {
                                let blockElement;

                                if (block.isMultiline && block.lines && block.lines.length > 0) {
                                    // Създаване на многоредов блок
                                    blockElement = blockManager.createMultilineBlock({
                                        groupId: block.groupId,
                                        blockType: block.blockType,
                                        orderMatters: !block.isOrderIndependent,
                                        lines: block.lines.map(line => ({
                                            content: line.content,
                                            optional: line.isOptional
                                        }))
                                    });
                                } else {
                                    // Създаване на обикновен блок
                                    blockElement = document.createElement('div');
                                    blockElement.className = 'code-block';
                                    blockElement.innerHTML = `<span class="code-content">${block.content}</span>`;
                                }

                                // Добавяне към source панела
                                if (!block.isDistractor) {
                                    document.getElementById('sourcePanel').appendChild(blockElement);
                                }
                            });
                    blockManager.initializePuzzleBlocks(puzzleBlocks);
                    </text>
            }



            new Sortable(sourcePanel, {
                group: 'code-blocks',
                animation: 150,
                onAdd: function(evt) {
                    const block = evt.item;
                    block.style.marginLeft = '0px';
                    block.classList.remove('distractor');
                }
            });

            new Sortable(targetPanel, {
                group: 'code-blocks',
                animation: 150,
                ghostClass: 'sortable-ghost',
                onAdd: function(evt) {
                    addIndentButtons(evt.item);
                    updateBraces();
                },
                onSort: function() {
                    updateBraces();
                },
                onStart: function(evt) {
                    dropIndicator.style.display = 'block';
                },
                onEnd: function(evt) {
                    dropIndicator.style.display = 'none';
                },
                onMove: function(evt) {
                    const related = evt.related;
                    if (related) {
                        const rect = related.getBoundingClientRect();
                        const y = evt.originalEvent.clientY;
                        const indent = parseInt(related.style.marginLeft || 0) / 20;
                        dropIndicator.style.top = (y < rect.top + rect.height / 2 ? rect.top : rect.bottom) + 'px';
                        dropIndicator.style.left = (rect.left + indent * 20) + 'px';
                        dropIndicator.style.width = (rect.width - indent * 20) + 'px';
                    }
                }
            });

            new Sortable(miniBlocksPanel, {
                group: { name: 'mini-blocks', pull: true, put: false },
                animation: 150
            });

            document.querySelectorAll('.code-block').forEach(block => {
                const slot = block.querySelector('.slot');
                if (slot) {
                    new Sortable(slot, {
                        group: 'mini-blocks',
                        animation: 150,
                        onAdd: function(evt) {
                            const miniBlock = evt.item;
                            slot.classList.add('filled');
                            const removeBtn = document.createElement('span');
                            removeBtn.className = 'remove-mini-block';
                            removeBtn.textContent = 'X';
                            removeBtn.onclick = () => {
                                miniBlocksPanel.appendChild(miniBlock);
                                removeBtn.remove();
                                slot.classList.remove('filled');
                            };
                            slot.appendChild(removeBtn);
                        }
                    });
                }
            });
        }

        function addIndentButtons(block) {
            if (!block.querySelector('.indent-btns')) {
                const buttons = document.createElement('span');
                buttons.className = 'indent-btns';
                buttons.innerHTML = '<button onclick="shiftLeft(this)" class="btn btn-sm btn-outline-secondary mx-1"><</button><button onclick="shiftRight(this)" class="btn btn-sm btn-outline-secondary">></button>';
                block.appendChild(buttons);
            }
        }

        function shiftLeft(btn) {
            const block = btn.closest('.code-block');
            let indent = parseInt(block.style.marginLeft || 0);
            if (indent > 0) {
                block.style.marginLeft = `${indent - 20}px`;
                updateBraces();
            }
        }

        function shiftRight(btn) {
            const block = btn.closest('.code-block');
            let indent = parseInt(block.style.marginLeft || 0);
            block.style.marginLeft = `${indent + 20}px`;
            updateBraces();
        }

        function updateBraces() {
            if (!['C', 'Cpp', 'CSharp', 'Java', 'JavaScript'].includes('@Model.Puzzle.Language.ToString()')) return;

            document.querySelectorAll('.brace-block').forEach(b => b.remove());
            const blocks = Array.from(document.querySelectorAll('#targetPanel .code-block'));
            let braceStack = [];

            blocks.forEach((block, i) => {
                const indent = parseInt(block.style.marginLeft || 0) / 20;
                if (indent === 0) {
                    while (braceStack.length) {
                        const closed = braceStack.pop();
                        const closeBrace = document.createElement('div');
                        closeBrace.className = `brace-block indent-${closed.braceLevel}`;
                        closeBrace.textContent = '}';
                        block.before(closeBrace);
                    }
                } else if (i > 0) {
                    const prevBlock = blocks[i - 1];
                    const prevIndent = parseInt(prevBlock.style.marginLeft || 0) / 20;
                    while (braceStack.length && braceStack[braceStack.length - 1].indent > indent) {
                        const closed = braceStack.pop();
                        const closeBrace = document.createElement('div');
                        closeBrace.className = `brace-block indent-${closed.braceLevel}`;
                        closeBrace.textContent = '}';
                        block.before(closeBrace);
                    }
                    if (indent > prevIndent) {
                        const braceLevel = prevIndent;
                        const openBrace = document.createElement('div');
                        openBrace.className = `brace-block indent-${braceLevel}`;
                        openBrace.textContent = '{';
                        block.before(openBrace);
                        braceStack.push({ indent, braceLevel });
                    }
                }
            });

            while (braceStack.length) {
                const closed = braceStack.pop();
                const closeBrace = document.createElement('div');
                closeBrace.className = `brace-block indent-${closed.braceLevel}`;
                closeBrace.textContent = '}';
                document.getElementById('targetPanel').appendChild(closeBrace);
            }
        }

        function getArrangement() {
            const targetPanel = document.getElementById('targetPanel');

            @if (Model.PuzzleBlocks != null && Model.PuzzleBlocks.Any())
            {
                <text>
                return blockManager.exportSolution(targetPanel);
                </text>
            }
            else
            {
                <text>
                // Използваме съществуващата логика
                const blocks = Array.from(targetPanel.children);
                if (blocks.length === 0) {
                    return '';
                }

                const blocks = Array.from(targetPanel.children);
                if (blocks.length === 0) {
                    return '';
                }

                return blocks.map(block => {
                    let indent = 0;
                    let content = '';

                    if (block.classList.contains('code-block') || block.classList.contains('brace-block')) {

                        if (block.classList.contains('brace-block')) {
                            return block.textContent.trim();
                        }

                        indent = parseInt(block.style.marginLeft || 0) / 20;
                        const codeContent = block.querySelector('.code-content');
                        if (!codeContent) return '';

                        const textNodes = [];
                        const walker = document.createTreeWalker(codeContent, NodeFilter.SHOW_TEXT, null, false);
                        while (walker.nextNode()) {
                            const node = walker.currentNode;
                            if (!node.parentElement.closest('.remove-mini-block')) {
                                textNodes.push(node.nodeValue);
                            }
                        }
                        content = textNodes.join('');

                        const slot = block.querySelector('.slot');
                        if (slot && slot.classList.contains('filled')) {
                            const miniBlock = slot.querySelector('.mini-block');
                            if (miniBlock) {
                                const slotName = slot.dataset.slot;
                                const miniBlockText = miniBlock.firstChild ? miniBlock.firstChild.nodeValue : '';
                                content = content.replace(`§${slotName}§`, miniBlockText);
                            } else {
                                content = content.replace(/§\w+§/, '');
                            }
                        }
                    }

                    return '  '.repeat(indent) + content;
                }).filter(line => line).join('\n');
                    </text>
            }
        }  

        async function checkSolution() {
            try {
                const arrangement = getArrangement();
                if (!arrangement) {
                    alert('Моля, добавете кодови блокове в целевия панел.');
                    return;
                }
                console.log('Sending check request with arrangement:', arrangement);
                const response = await fetch('/api/PuzzleApi/check', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        puzzleId: @Model.Puzzle.Id,
                        arrangement
                    })
                });
                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`Server error: ${response.status} - ${errorText}`);
                }
                const result = await response.json();
                alert(result.isCorrect ? 'Решението е вярно!' : 'Решението е грешно.');
            } catch (error) {
                console.error('Error checking solution:', error);
                alert('Грешка при проверка на решението. Моля, опитайте отново.');
            }
        }

        async function submitSolution() {
            try {
                const arrangement = getArrangement();
                if (!arrangement) {
                    alert('Моля, добавете кодови блокове в целевия панел.');
                    return;
                }
                const timeTaken = Math.floor((Date.now() - startTime) / 1000);
                console.log('Sending submit request with arrangement:', arrangement, 'timeTaken:', timeTaken);
                const response = await fetch('/api/PuzzleApi/submit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        bundleId: @Model.Bundle.Id,
                        puzzleId: @Model.Puzzle.Id,
                        puzzleIndex: @Model.PuzzleIndex,
                        studentIdentifier: '@Model.StudentIdentifier',
                        arrangement,
                        timeTaken,
                        bundleAttemptId: '@Model.BundleAttemptId'
                    })
                });
                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`Server error: ${response.status} - ${errorText}`);
                }
                const result = await response.json();
                if (result.isLast) {
                    const stats = result.statistics;
                    alert(`Колекцията с пъзели е завършена!\n\nСтатистика:\n- Общо опити: ${stats.totalAttempts}\n- Верни решения: ${stats.correctAttempts}\n- Грешни решения: ${stats.incorrectAttempts}`);
                    window.location.href = result.nextUrl;
                } else {
                    alert(result.isCorrect ? 'Решението е вярно! Преминавате към следващия пъзел.' : 'Решението е грешно. Преминавате към следващия пъзел.');
                    window.location.href = result.nextUrl;
                }
            } catch (error) {
                console.error('Error submitting solution:', error);
                alert('Грешка при подаване на решението. Моля, опитайте отново.');
            }
        }

        function resetPuzzle() {
            window.location.reload();
        }

        initializePuzzle();
    </script>
}