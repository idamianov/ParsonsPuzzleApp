@page
@model ParsonsPuzzleApp.Pages.Instructor.LtiPlatformsModel
@{
    ViewData["Title"] = "LTI Platforms";
}

<h1>LTI Platform Management</h1>

<p class="text-muted">
    Configure LTI 1.3 platforms (LMS) to enable seamless integration with Moodle, Blackboard, and other learning management systems.
</p>

@if (!string.IsNullOrEmpty(Model.SetupMessage))
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <strong>LTI Setup Required:</strong> @Model.SetupMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p>
    <a asp-page="CreateLtiPlatform" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Register New Platform
    </a>
</p>

@if (Model.Platforms.Any())
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Platform Name</th>
                    <th>Issuer</th>
                    <th>Client ID</th>
                    <th>Deployments</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var platform in Model.Platforms)
                {
                    <tr>
                        <td>
                            <strong>@platform.Name</strong>
                        </td>
                        <td>
                            <code class="small">@platform.Issuer</code>
                        </td>
                        <td>
                            <code class="small">@platform.ClientId</code>
                        </td>
                        <td>
                            @{
                                var activeDeployments = platform.Deployments.Count(d => d.IsActive);
                                var configuredDeployments = platform.Deployments.Count(d => d.BundleId != null);
                            }
                            <span class="badge bg-info">@activeDeployments total</span>
                            @if (configuredDeployments > 0)
                            {
                                <span class="badge bg-success">@configuredDeployments linked</span>
                            }
                        </td>
                        <td>
                            @if (platform.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>@platform.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-page="EditLtiPlatform" asp-route-id="@platform.Id" class="btn btn-sm btn-info">
                                    Edit
                                </a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@platform.Id" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Are you sure you want to delete this platform? All deployments will also be deleted.')">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">
        <h5>No LTI Platforms Registered</h5>
        <p>To integrate with your LMS, you need to register it as an LTI platform.</p>
        <hr>
        <p class="mb-0">
            <a asp-page="CreateLtiPlatform" class="btn btn-primary">Register Your First Platform</a>
        </p>
    </div>
}

<div class="card mt-4">
    <div class="card-header">
        <h5 class="mb-0">Tool Configuration for LMS</h5>
    </div>
    <div class="card-body">
        <p>When configuring this tool in your LMS, use the following URLs:</p>
        <table class="table table-sm">
            <tr>
                <th>Login Initiation URL</th>
                <td><code>@Url.ActionLink("Login", "Lti", null, Request.Scheme)</code></td>
            </tr>
            <tr>
                <th>Launch/Redirect URL</th>
                <td><code>@Url.ActionLink("Launch", "Lti", null, Request.Scheme)</code></td>
            </tr>
            <tr>
                <th>Public Keyset URL (JWKS)</th>
                <td><code>@($"{Request.Scheme}://{Request.Host}/.well-known/jwks.json")</code></td>
            </tr>
        </table>
    </div>
</div>
